# Polymarket Price Tracker — environment config (copy to .env, never commit .env)

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Database ---
DB_PATH=prices.db

# --- Collector ---
DEFAULT_POLL_INTERVAL=5        # seconds; per-market override lives in the DB
HTTP_TIMEOUT=30                # generous: throttled-but-slow responses are successes
MAX_RETRIES=5                  # exponential backoff with jitter on HTTP 429

# --- Screener ---
SCREENER_REFRESH_MINUTES=5     # how often the match cache is rebuilt

# --- Polymarket public APIs (no keys needed, read-only) ---
GAMMA_BASE_URL=https://gamma-api.polymarket.com
CLOB_BASE_URL=https://clob.polymarket.com

# --- Logging ---
LOG_LEVEL=INFO
